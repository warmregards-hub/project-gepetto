# API Keys
KIE_API_KEY=your_kie_api_key_here
KIE_BASE_URL=https://api.kie.ai/v1
KIE_CHAT_MODEL=gemini-2.5-flash
KIE_CHAT_REASONING=low
KIE_CHAT_TEMPERATURE=0.2
KIE_TRACE_ENABLED=true
KIE_TRACE_PATH=/app/kie_trace.jsonl
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
VITE_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here

# Services
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
GOOGLE_SERVICE_ACCOUNT_JSON={}
GOOGLE_DRIVE_FOLDER_ID=
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=WR-ProjectGepetto

# Database
POSTGRES_USER=hub
POSTGRES_PASSWORD=password
POSTGRES_DB=creative_hub
# DATABASE_URL is constructed in docker-compose.yml

# App Config
ENVIRONMENT=development
SECRET_KEY=super_secret_jwt_signing_key_change_me_in_production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Cost Limits (USD)
COST_LIMIT_SESSION=5.00
COST_LIMIT_MONTHLY=150.00

# Admin User (bcrypt hash of 'password' for local dev)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6Lruj3vjIQqiRQYq

# Storage & Mocks
STORAGE_PATH=/storage
MOCK_GENERATION=true
ENDPOINT_REGISTRY_PATH=/app/endpoint_registry.json
MODEL_CACHE_PATH=/app/model_cache.json
